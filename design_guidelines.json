{
  "identity": {
    "name": "E1",
    "persona": "The Anti-AI Designer",
    "principles": [
      "Fusion over Imitation",
      "Emotion First",
      "Content is King",
      "Zoom In",
      "Negative Space",
      "Contrast"
    ]
  },
  "project": {
    "name": "SteelMicroStructureAI",
    "type": "Scientific Dashboard",
    "theme": "Dark Industrial",
    "emotional_tone": "Precision, Reliability, High-Tech, Industrial Heat",
    "target_audience": "Materials Scientists, Metallurgical Engineers, QC Engineers"
  },
  "typography": {
    "font_family": {
      "headings": "JetBrains Mono, monospace",
      "body": "Manrope, sans-serif",
      "data": "JetBrains Mono, monospace"
    },
    "weights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "black": 900
    },
    "usage": {
      "h1": "text-4xl md:text-5xl font-bold tracking-tight font-mono text-white",
      "h2": "text-3xl font-bold tracking-tight font-mono text-white/90",
      "h3": "text-xl font-semibold tracking-wide font-mono text-white/80 uppercase",
      "body": "text-base leading-relaxed text-slate-300 font-sans",
      "label": "text-xs font-bold tracking-widest uppercase text-slate-500 font-mono",
      "data_value": "text-2xl font-mono font-bold text-cyan-400"
    }
  },
  "colors": {
    "palette": {
      "background": {
        "default": "#0A0A0A",
        "paper": "#111111",
        "subtle": "#1A1A1A"
      },
      "primary": {
        "main": "#007AFF",
        "light": "#60A5FA",
        "dark": "#0056B3",
        "glow": "0 0 20px rgba(0, 122, 255, 0.5)"
      },
      "secondary": {
        "main": "#FF3B30",
        "light": "#FF6B6B",
        "dark": "#B31D15",
        "desc": "Used for heat/temperature related data"
      },
      "neutral": {
        "100": "#FFFFFF",
        "200": "#E5E5E5",
        "300": "#D4D4D4",
        "400": "#A3A3A3",
        "500": "#737373",
        "600": "#525252",
        "700": "#404040",
        "800": "#262626",
        "900": "#171717"
      },
      "semantic": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      }
    },
    "gradients": {
      "hero": "linear-gradient(to bottom right, #0A0A0A, #111111)",
      "glow_blue": "radial-gradient(circle at center, rgba(0, 122, 255, 0.15) 0%, transparent 70%)",
      "glow_heat": "radial-gradient(circle at center, rgba(255, 59, 48, 0.1) 0%, transparent 70%)"
    }
  },
  "layout": {
    "grid_system": "Bento Grid (Mode B)",
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "spacing": {
      "section_gap": "py-20",
      "component_gap": "gap-6",
      "internal_padding": "p-6 md:p-8"
    },
    "z_index": {
      "base": 0,
      "overlay": 10,
      "modal": 50,
      "toast": 100
    }
  },
  "components": {
    "cards": {
      "style": "bg-[#111111] border border-white/10 rounded-none relative overflow-hidden",
      "hover": "hover:border-cyan-500/50 transition-colors duration-300",
      "decoration": "Use 'Tracing Beam' effect or corner accents"
    },
    "buttons": {
      "primary": "bg-white text-black hover:bg-cyan-400 hover:text-black font-mono uppercase tracking-wider text-sm px-6 py-3 rounded-none transition-all duration-200 shadow-[0_0_15px_rgba(255,255,255,0.1)] hover:shadow-[0_0_20px_rgba(6,182,212,0.4)]",
      "secondary": "bg-transparent border border-white/20 text-white hover:border-white hover:bg-white/5 font-mono uppercase tracking-wider text-sm px-6 py-3 rounded-none transition-all"
    },
    "inputs": {
      "style": "bg-black/50 border-white/20 text-white font-mono focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 rounded-none h-12",
      "label": "text-xs text-slate-400 uppercase tracking-widest mb-2 block"
    },
    "charts": {
      "library": "Recharts",
      "theme": {
        "background": "transparent",
        "grid": "#333",
        "text": "#888",
        "colors": ["#007AFF", "#FF3B30", "#10B981", "#F59E0B"]
      }
    }
  },
  "visual_enhancers": {
    "glassmorphism": "backdrop-blur-xl bg-black/60 border border-white/10",
    "grid_lines": "bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]",
    "glow_effects": "drop-shadow-[0_0_8px_rgba(0,122,255,0.5)]"
  },
  "image_urls": {
    "hero_background": "https://images.unsplash.com/photo-1720036236697-018370867320?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1ODF8MHwxfHNlYXJjaHwxfHxpbmR1c3RyaWFsJTIwc3RlZWwlMjBtYW51ZmFjdHVyaW5nJTIwZmFjdG9yeSUyMGRhcmt8ZW58MHx8fHwxNzY4ODQzNTcxfDA&ixlib=rb-4.1.0&q=85",
    "heat_treatment_context": "https://images.unsplash.com/photo-1697281679290-ad7be1b10682?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1ODF8MHwxfHNlYXJjaHw0fHxpbmR1c3RyaWFsJTIwc3RlZWwlMjBtYW51ZmFjdHVyaW5nJTIwZmFjdG9yeSUyMGRhcmt8ZW58MHx8fHwxNzY4ODQzNTcxfDA&ixlib=rb-4.1.0&q=85",
    "microstructure_example": "https://images.unsplash.com/photo-1694701478292-3f60eb30c3b3?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1Nzd8MHwxfHNlYXJjaHwxfHxzdGVlbCUyMG1pY3Jvc3RydWN0dXJlJTIwbWljcm9zY29wZXxlbnwwfHx8fDE3Njg4NDM1NzB8MA&ixlib=rb-4.1.0&q=85",
    "processing_context": "https://images.unsplash.com/photo-1562045289-8e02d9a3a61f?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1Nzd8MHwxfHNlYXJjaHw0fHxzdGVlbCUyMG1pY3Jvc3RydWN0dXJlJTIwbWljcm9zY29wZXxlbnwwfHx8fDE3Njg4NDM1NzB8MA&ixlib=rb-4.1.0&q=85"
  },
  "instructions_to_main_agent": [
    "Use .jsx extension for all React components.",
    "Implement the 'Bento Grid' layout for the main dashboard.",
    "Use 'JetBrains Mono' for all numerical data and headers to emphasize the scientific nature.",
    "Ensure all inputs have 'data-testid' attributes.",
    "The 'Phase Diagram' should be an interactive component (use Recharts scatter/line plot or custom SVG).",
    "Use the 'dark' class on the root element or body to enforce dark mode.",
    "Do not use gradients for backgrounds; use solid dark colors with subtle noise or grid overlays.",
    "Inputs should look like industrial control fields (rectangular, distinct borders).",
    "Add a 'Regime Classification' badge that changes color based on the carbon content (Hypoeutectoid: Blue, Eutectoid: Green, Hypereutectoid: Orange, Cementite: Red)."
  ],
  "universal_guidelines": [
    "Avoid 'AI slop' - no generic centered layouts.",
    "Use 2-3x more spacing than typical.",
    "Every interaction needs micro-animations.",
    "Use 'sonner' for toasts.",
    "Components must use named exports.",
    "Pages must use default exports."
  ]
}